<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>AI News Radar RSS Example</title>
  </head>
  <body>
    <outline text="AI Coding Tools">
      <outline
        text="OpenAI Blog"
        title="OpenAI Blog"
        type="rss"
        xmlUrl="https://openai.com/blog/rss.xml"
        htmlUrl="https://openai.com/blog"
      />
      <outline
        text="GitHub AI &amp; ML"
        title="GitHub AI &amp; ML"
        type="rss"
        xmlUrl="https://github.blog/ai-and-ml/feed/"
        htmlUrl="https://github.blog/ai-and-ml/"
      />
      <outline
        text="Hugging Face Blog"
        title="Hugging Face Blog"
        type="rss"
        xmlUrl="https://huggingface.co/blog/feed.xml"
        htmlUrl="https://huggingface.co/blog"
      />
      <outline
        text="Simon Willison"
        title="Simon Willison"
        type="rss"
        xmlUrl="https://simonwillison.net/atom/everything/"
        htmlUrl="https://simonwillison.net/"
      />
      <outline
        text="Cursor Blog"
        title="Cursor Blog"
        type="rss"
        xmlUrl="https://cursor.com/blog/rss.xml"
        htmlUrl="https://cursor.com/blog"
      />
    </outline>
    <outline text="Agents and MCP">
      <outline
        text="LangChain Blog"
        title="LangChain Blog"
        type="rss"
        xmlUrl="https://blog.langchain.dev/rss/"
        htmlUrl="https://blog.langchain.dev/"
      />
      <outline
        text="OpenAI Skills"
        title="OpenAI Skills"
        type="rss"
        xmlUrl="https://github.com/openai/skills/commits/main.atom"
        htmlUrl="https://github.com/openai/skills"
      />
    </outline>
    <outline text="AI Industry Trends">
      <outline
        text="TechCrunch AI"
        title="TechCrunch AI"
        type="rss"
        xmlUrl="https://techcrunch.com/category/artificial-intelligence/feed/"
        htmlUrl="https://techcrunch.com/category/artificial-intelligence/"
      />
      <outline
        text="The Verge AI"
        title="The Verge AI"
        type="rss"
        xmlUrl="https://www.theverge.com/rss/ai-artificial-intelligence/index.xml"
        htmlUrl="https://www.theverge.com/ai-artificial-intelligence"
      />
    </outline>
  </body>
</opml>
